{
  "name": "csfd-ranking",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "pages:build": "npx @cloudflare/next-on-pages",
    "preview": "npm run pages:build && wrangler pages dev",
    "deploy": "npm run pages:build && wrangler pages deploy",
    "db:migrate": "wrangler d1 migrations apply csfd-ranking-db",
    "db:migrate:local": "wrangler d1 migrations apply csfd-ranking-db --local",
    "scrape": "npx tsx scripts/scrape-csfd.ts",
    "seed": "npx tsx scripts/seed-db.ts"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "cheerio": "^1.0.0",
    "framer-motion": "^11.15.0",
    "jose": "^5.9.6",
    "next": "15.2.2",
    "node-fetch": "^3.3.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.7",
    "@cloudflare/workers-types": "^4.20241224.0",
    "@opennextjs/cloudflare": "^1.17.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.17.10",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "playwright": "^1.58.2",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "wrangler": "^3.101.0"
  }
}
